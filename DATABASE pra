3) Cursor-Based Stored Procedure (Grade Assignment)
DELIMITER $$

DROP PROCEDURE IF EXISTS assign_grades $$

CREATE PROCEDURE assign_grades()
BEGIN
    -- Variables to hold fetched values
    DECLARE v_roll INT;
    DECLARE v_marks INT;
    DECLARE v_grade CHAR(2);

    -- Cursor control variable
    DECLARE done INT DEFAULT 0;

    -- Declare cursor
    DECLARE cur_students CURSOR FOR
        SELECT roll_no, marks FROM student_marks;

    -- Handler: when cursor finishes, set done = 1
    DECLARE CONTINUE HANDLER FOR NOT FOUND SET done = 1;

    -- Open cursor
    OPEN cur_students;

    grade_loop: LOOP
        -- Fetch row into variables
        FETCH cur_students INTO v_roll, v_marks;

        -- Exit loop when no more rows
        IF done = 1 THEN
            LEAVE grade_loop;
        END IF;

        -- Grade logic
        IF v_marks >= 90 THEN
            SET v_grade = 'A';
        ELSEIF v_marks >= 75 THEN
            SET v_grade = 'B';
        ELSEIF v_marks >= 60 THEN
            SET v_grade = 'C';
        ELSEIF v_marks >= 40 THEN
            SET v_grade = 'D';
        ELSE
            SET v_grade = 'F';
        END IF;

        -- Update grade
        UPDATE student_marks
        SET grade = v_grade
        WHERE roll_no = v_roll;

    END LOOP;

    -- Close cursor
    CLOSE cur_students;
END $$

DELIMITER ;
