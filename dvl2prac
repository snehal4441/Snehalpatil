11) Histograms For Data Visualization - use hist() to create histograms in NumPy. example. 
import numpy as np
import matplotlib.pyplot as plt
 # Generate random data using NumPy
 data = np.random.normal(50, 10, 100) 
# mean = 50, standard deviation = 10, 100 values
 # Create histogram
 plt.hist(data, bins=10) 
# Labels and Title
 plt.xlabel("Value Range")
 plt.ylabel("Frequency")
 plt.title("Histogram Example") 
# Show graph
plt.show()

  
 
